# ===== 内网大模型 API（OpenAI 兼容格式）=====
# 网关地址，例如 http://10.0.0.1:8000/v1
LLM_BASE_URL=http://your-internal-gateway/v1
LLM_API_KEY=sk-your-internal-key
LLM_MODEL=your-model-name

# 内网 https 网关用自签证书时（curl 需要 -k 才能访问）：
#   LLM_VERIFY_SSL=false          # 关闭证书校验，等效 curl -k（内网可接受）
#   LLM_CA_BUNDLE=/path/to/ca.pem # 或指定 CA 证书，比关闭校验更安全（二选一，优先用它）
LLM_VERIFY_SSL=true
LLM_CA_BUNDLE=

# ===== 数据文件路径 =====
STUDENTS_XLSX=data/students.xlsx
TOPICS_XLSX=data/topics.xlsx
OUTPUT_DIR=output

# ===== 推荐参数 =====
# 每位同学推荐几个课题
TOP_N=3
# 采样温度，越低越稳定（推荐 0.2）
TEMPERATURE=0.2
# 单次请求超时（秒）
LLM_TIMEOUT=60
# 失败重试次数
LLM_MAX_RETRIES=3
